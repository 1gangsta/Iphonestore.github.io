  top: 0;
  z-index: 10;
  backdrop-filter: blur(18px);
  background: rgba(4, 8, 20, 0.78);
  border-bottom: 1px solid rgba(148, 163, 184, 0.08);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1rem 0;
}

.logo {
  font-size: 1.3rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: white;
}

.nav-links {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
}

.nav-links a {
  color: #cbd5e1;
  text-decoration: none;
  transition: color 0.2s ease;
}

.nav-links a:hover,
.nav-links a.active {
  color: white;
}

.page-hero {
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.6), rgba(2, 6, 23, 0.9));
  border: 1px solid rgba(148, 163, 184, 0.1);
  border-radius: 2rem;
  padding: 3.5rem 2rem;
  margin-bottom: 2rem;
}

.page-hero .hero-copy {
  max-width: 52rem;
}

.page-hero h2 {
  margin: 0 0 1rem;
  font-size: clamp(2.4rem, 4vw, 3.5rem);
}

.page-hero p {
  color: #cbd5e1;
  max-width: 42rem;
}

.page-hero .button {
  margin-top: 1.75rem;
}

.content {
  padding: 2rem 0;
  max-width: 900px;
  color: #cbd5e1;
}

.hero {
  position: relative;
  padding: 4rem 0 2rem;
  overflow: hidden;
}

.hero-background {
  position: absolute;
  inset: 0;
  z-index: 0;
  display: grid;
}

.hero-background::after {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top, rgba(15, 23, 42, 0.35), transparent 40%),
    linear-gradient(180deg, rgba(15, 23, 42, 0.25), rgba(2, 6, 23, 0.55));
  pointer-events: none;
}

.slide {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  opacity: 0;
  animation: slideFade 15s infinite;
}

.slide-1 {
  background-image: linear-gradient(180deg, rgba(15, 23, 42, 0.25), rgba(2, 6, 23, 0.45)),
    url('images/image 1.jfif');
  background-blend-mode: normal;
  filter: brightness(1.08);
}

.slide-2 {
  background-image: linear-gradient(180deg, rgba(15, 23, 42, 0.25), rgba(2, 6, 23, 0.45)),
    url('images/image 2.jfif');
  background-blend-mode: normal;
  filter: brightness(1.08);
}

.slide-3 {
  background-image: linear-gradient(180deg, rgba(15, 23, 42, 0.25), rgba(2, 6, 23, 0.45)),
    url('images/image 3.jfif');
  background-blend-mode: normal;
  filter: brightness(1.08);
}

.slide:nth-child(1) {
  animation-delay: 0s;
}

.slide:nth-child(2) {
  animation-delay: 5s;
}

.slide:nth-child(3) {
  animation-delay: 10s;
}

@keyframes slideFade {
  0%, 25% {
    opacity: 0;
  }
  30%, 55% {
    opacity: 1;
  }
  60%, 100% {
    opacity: 0;
  }
}

.hero-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: center;
}

.hero-copy h1 {
  font-size: clamp(2.75rem, 4vw, 4.5rem);
  margin: 0;
  line-height: 1.03;
  max-width: 14ch;
}

.hero-copy p {
  max-width: 44rem;
  color: #cbd5e1;
  margin-top: 1.5rem;
}

.eyebrow {
  display: inline-block;
  margin-bottom: 1rem;
  color: #38bdf8;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 0.82rem;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-top: 2rem;
}

.hero-image {
  display: flex;
  justify-content: center;
}

.phone-frame {
  width: min(360px, 100%);
  aspect-ratio: 9 / 18.5;
  border-radius: 3rem;
  background: linear-gradient(180deg, rgba(59, 130, 246, 0.2), rgba(14, 165, 233, 0.08));
  box-shadow: 0 40px 120px rgba(15, 23, 42, 0.35);
  padding: 1.5rem;
  display: grid;
  place-items: center;
}

.phone-screen {
  width: 100%;
  height: 100%;
  border-radius: 2.4rem;
  background: linear-gradient(180deg, #0f172a 0%, #0b1120 55%, #09101f 100%);
  box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.08);
  display: grid;
  place-items: center;
  padding: 1.5rem;
  gap: 1rem;
}

.screen-status {
  width: 100%;
  display: flex;
  justify-content: space-between;
  color: #94a3b8;
  font-size: 0.95rem;
  letter-spacing: 0.02em;
}

.dynamic-display {
  width: 100%;
  max-width: 18rem;
  text-align: center;
  color: #f8fafc;
}

.dynamic-display .display-label {
  margin: 0;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: #38bdf8;
}

.dynamic-display h2 {
  margin: 0.5rem 0 0.75rem;
  font-size: 1.6rem;
  line-height: 1.1;
}

.dynamic-display p {
  margin: 0;
  color: #cbd5e1;
  font-size: 0.95rem;
}

.display-features {
  margin-top: 1.25rem;
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  flex-wrap: wrap;
}

.display-features span {
  background: rgba(148, 163, 184, 0.1);
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 999px;
  padding: 0.65rem 0.9rem;
  font-size: 0.85rem;
  color: #cbd5e1;
}

.screen-info span {
  padding: 0.8rem 1rem;
  background: rgba(148, 163, 184, 0.08);
  border-radius: 1rem;
  font-size: 0.96rem;
}

.section {
  padding: 4rem 0;
}

.section-heading {
  max-width: 52rem;
  margin-bottom: 2.5rem;
}

.section-heading h2 {
  margin: 0.5rem 0 0;
  font-size: clamp(2rem, 3vw, 3rem);
}

.feature-grid,
.product-grid,
.stats-grid {
  display: grid;
  gap: 1.5rem;
}

.feature-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.feature-card {
  background: rgba(148, 163, 184, 0.08);
  border: 1px solid rgba(148, 163, 184, 0.12);
  border-radius: 1.5rem;
  padding: 2rem;
}

.feature-card h3 {
  margin-top: 0;
  margin-bottom: 0.75rem;
  color: white;
}

.feature-card p {
  margin: 0;
  color: #cbd5e1;
}

.product-grid {
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.product-card {
  background: rgba(15, 23, 42, 0.92);
  border: 1px solid rgba(148, 163, 184, 0.12);
  border-radius: 1.75rem;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.product-image {
  min-height: 260px;
  background-size: cover;
  background-position: center;
}

.image-1 {
  background-image: url('images/image 1.jfif');
}

.image-2 {
  background-image: url('images/image 2.jfif');
}

.image-3 {
  background-image: url('images/image 3.jfif');
}

.image-4 {
  background-image: linear-gradient(180deg, rgba(59, 130, 246, 0.22), rgba(15, 23, 42, 0.9)),
    radial-gradient(circle at 30% 20%, rgba(96, 165, 250, 0.45), transparent 26%),
    linear-gradient(135deg, #0f172a 0%, #111827 100%);
}

.image-5 {
  background-image: linear-gradient(180deg, rgba(201, 21, 74, 0.22), rgba(15, 23, 42, 0.9)),
    radial-gradient(circle at 65% 25%, rgba(251, 113, 133, 0.35), transparent 24%),
    linear-gradient(135deg, #111827 0%, #0f172a 100%);
}

.product-copy {
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.product-copy h3 {
  margin: 0;
  color: white;
}

.product-copy p {
  margin: 0;
  color: #cbd5e1;
}

.product-footer {
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.price {
  font-size: 1.3rem;
  font-weight: 700;
  color: #f8fafc;
}

.about-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 2rem;
  align-items: center;
}

.about-grid p {
  color: #cbd5e1;
}

.stats-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.stat-card {
  border-radius: 1.5rem;
  background: rgba(148, 163, 184, 0.08);
  padding: 1.75rem;
  text-align: center;
}

.stat-card strong {
  display: block;
  font-size: 2rem;
  color: white;
}

.stat-card span {
  display: block;
  margin-top: 0.5rem;
  color: #cbd5e1;
}

.site-footer {
  padding: 3rem 0 2rem;
  border-top: 1px solid rgba(148, 163, 184, 0.1);
}

.footer-grid {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1.5rem;
}

.footer-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.footer-note {
  margin-top: 2rem;
  color: #94a3b8;
  font-size: 0.95rem;
}

@media (max-width: 860px) {

  .hero-grid,
  .about-grid {
    grid-template-columns: 1fr;
  }

  .feature-grid,
  .product-grid,
  .stats-grid {
    grid-template-columns: 1fr;
  }

  .header-inner {
    flex-direction: column;
    align-items: flex-start;
  }
}

@media (max-width: 640px) {
  .hero {
    padding-top: 2.5rem;
  }

  .nav-links {
    flex-wrap: wrap;
    gap: 1rem;
  }

  .feature-card,
  .product-card,
  .stat-card {
    padding: 1.5rem;
  }
}
